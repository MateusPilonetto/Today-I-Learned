programa {
  funcao inicio() {
    escreva("Qual a primeira nota?")
    real nota1
    leia(nota1)

    escreva("Qual a segunda nota?")
    real nota2
    leia(nota2)

    escreva("Qual a terceira nota?")
    real nota3
    leia(nota3)

    inteiro Qntd = 3

    escreva("A média das nota é ", (nota1 + nota2 + nota3) / Qntd)
    
  }
}
